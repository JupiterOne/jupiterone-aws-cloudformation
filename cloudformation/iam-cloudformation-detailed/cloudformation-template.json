      "Properties": {
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/SecurityAudit",
          {
            "Ref": "JupiterOneSecurityAuditPolicy"
          },
          {
            "Ref": "JupiterOneSecurityAuditPolicy2"
          },
          {
            "Ref": "JupiterOneSecurityAuditPolicy3"
          }
        ],
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Action": "sts:AssumeRole",
              "Effect": "Allow",
              "Principal": {
                "AWS": {
                  "Ref": "JupiterOneAwsAccountArns"
                }
              },
              "Condition": {
                "StringEquals": {
                  "sts:ExternalId": {
                    "Ref": "JupiterOneExternalId"
                  }
                }
              }
            }
          ]
        }
      }
    }
  },
  "Outputs": {
    "RoleARN": {
      "Description": "ARN of the JupiterOne role",
      "Value": {
        "Fn::GetAtt": ["JupiterOneRole", "Arn"]
      }
    }
  }
}
